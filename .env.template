# Jobs funnel - Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to git

# Project root directory (used by workflow.json for script paths)
JOBS_FUNNEL_PROJECT_DIR=

# Active profile (reads from profiles/<name>/)
JOBS_FUNNEL_PROFILE=profile1

# Database table name (each profile uses its own table)
JOBS_FUNNEL_TABLE=jobs

# n8n auth (for local UI access)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# Webhook secret (optional, for bookmarklet validation)
JOBS_FUNNEL_WEBHOOK_SECRET=

# Review UI (python -m uvicorn ui.server:app --port $JOBS_FUNNEL_UI_PORT)
JOBS_FUNNEL_UI_PORT=8080
JOBS_FUNNEL_N8N_BASE=http://localhost:5678

# PostgreSQL (local storage)
JOBS_FUNNEL_PG_HOST=localhost
JOBS_FUNNEL_PG_PORT=5432
JOBS_FUNNEL_PG_DATABASE=jobs_funnel
JOBS_FUNNEL_PG_USER=postgres
JOBS_FUNNEL_PG_PASSWORD=changeme

# Embedding (Ollama + bge-m3, used by Phase 1 vector dedup + calibration)
OLLAMA_URL=http://localhost:11434
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024

# Phase 2 semantic dedup thresholds
DEDUP_THRESHOLD_CERTAIN=0.95
DEDUP_THRESHOLD_REVIEW=0.85
DEDUP_SCOPE_DAYS=30

# Future: Anthropic API key (for VPS migration, not needed locally)
# ANTHROPIC_API_KEY=sk-ant-...

# Re-enable Execute Command node (disabled by default in n8n 2.x)
NODES_EXCLUDE="[]"

# Gives access to env vars
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# Disable n8n telemetry / phone-home (silences PostHog + Rudder errors in logs)
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=false
N8N_TEMPLATES_ENABLED=false
N8N_PERSONALIZATION_ENABLED=false
N8N_HIRING_BANNER_ENABLED=false
EXTERNAL_FRONTEND_HOOKS_URLS=
N8N_DIAGNOSTICS_CONFIG_FRONTEND=
N8N_DIAGNOSTICS_CONFIG_BACKEND=
